{
  "name": "@rutan/midorable-platform-browser",
  "version": "0.1.0",
  "description": "Browser platform package for Midorable.",
  "keywords": [
    "game"
  ],
  "homepage": "https://github.com/rutan/midorable",
  "license": "MIT",
  "author": "rutan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rutan/midorable"
  },
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./canvas": {
      "types": "./dist/canvas/index.d.mts",
      "import": "./dist/canvas/index.mjs"
    },
    "./webgl": {
      "types": "./dist/webgl/index.d.mts",
      "import": "./dist/webgl/index.mjs"
    },
    "./webgpu": {
      "types": "./dist/webgpu/index.d.mts",
      "import": "./dist/webgpu/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "run-s build:*",
    "build:tsdown": "tsdown",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint --type-aware .",
    "lint:tsc": "tsgo",
    "test": "run-s test:*",
    "test:vitest": "vitest run test/unit",
    "test:browser": "playwright test",
    "format": "oxlint --type-aware --fix ."
  },
  "dependencies": {
    "@rutan/midorable": "workspace:*"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.69"
  },
  "engines": {
    "node": ">= 24.0"
  }
}
