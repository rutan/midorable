{
  "name": "particle-editor",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite preview",
    "dev": "vite",
    "build": "run-s gen build:*",
    "build:vite": "vite build --mode production",
    "gen": "typia generate --input src/typia/template --output src/typia/generated",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint .",
    "lint:tsc": "tsgo",
    "format": "run-s format:*",
    "format:oxlint": "oxlint --fix ."
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@rutan/midorable": "workspace:*",
    "@rutan/midorable-platform-browser": "workspace:*",
    "jotai": "^2.18.0",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "typia": "^11.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2"
  },
  "packageManager": "pnpm@10.28.2"
}
